{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web && pnpm build",
  "installCommand": "npm install -g pnpm@10.33.0 && cd web && pnpm install --frozen-lockfile",
  "devCommand": "cd web && pnpm dev",
  "outputDirectory": "web/.next",
  "framework": "nextjs",
  "regions": ["icn1"],
  "github": {
    "silent": true
  }
}
